# Generated project .replit — copied by materialize-project.sh into the
# generated Replit workspace root. Edit here; materialize propagates it.
#
# STACK LOCK: Java 21 + Node 22 + PostgreSQL 16. See replit.md.

modules = ["java-21", "nodejs-22", "postgresql-16"]
hidden  = [".idea", ".vscode", "target", "node_modules", "generated-sources", ".cache"]

# Boot hook — sets up runtime scripts; no-op if already materialized.
onBoot = "bash scripts/setup-project.sh"

[nix]
channel = "stable-24_11"

# === Deployment === Reserved VM (`gce`). Build + run wrapped in scripts.
[deployment]
deploymentTarget = "gce"
build = ["bash", "scripts/replit-build.sh"]
run   = ["bash", "scripts/replit-run.sh"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3000

[[ports]]
localPort = 5052
externalPort = 3001

[[ports]]
localPort = 5053
externalPort = 3002

# === Workspace env ===
[env]
PORT = "5000"
SPRING_PROFILES_ACTIVE = "replit"

# === Workflows ===
[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Run"
mode = "parallel"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mvn -f backend/pom.xml -B -DskipTests -Dcheckstyle.skip=true -Djacoco.skip=true -Dskip.frontend=true install && mvn -f backend/application/pom.xml -B -DskipTests -Dcheckstyle.skip=true -Djacoco.skip=true -Dskip.frontend=true spring-boot:run"
waitForPort = 5000

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run"

[agent]
expertMode = true

[userenv]

[userenv.shared]
AUTH_ALLOWED_EMAIL_DOMAIN = "aidigital.com"
AUTH_AUTHORIZED_PARTIES = "https://de1ddd8c-7885-4345-bdff-dbff942be7e0-00-3bdhs3ngq2l9d.spock.replit.dev,http://localhost:5173,http://localhost:5000,https://presentation-builder-poc.replit.app"
AUTH_ISSUER_URI = "https://living-insect-60.clerk.accounts.dev"
AUTH_JWKS_URI = "https://living-insect-60.clerk.accounts.dev/.well-known/jwks.json"
AUTH_MODE = "sso"
CLERK_PUBLISHABLE_KEY = "pk_test_bGl2aW5nLWluc2VjdC02MC5jbGVyay5hY2NvdW50cy5kZXYk"
VITE_AUTH_MODE = "sso"
VITE_CLERK_PUBLISHABLE_KEY = "pk_test_bGl2aW5nLWluc2VjdC02MC5jbGVyay5hY2NvdW50cy5kZXYk"
